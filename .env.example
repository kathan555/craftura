# ─── DATABASE ───────────────────────────────────────────────────
# SQLite (default — no setup needed)
DATABASE_URL="file:./dev.db"

# PostgreSQL (uncomment and update when migrating)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/craftura?schema=public"

# ─── AUTHENTICATION ─────────────────────────────────────────────
# IMPORTANT: Change these secrets in production!
JWT_SECRET="craftura-furniture-super-secret-jwt-key-change-in-prod"
NEXTAUTH_SECRET="craftura-nextauth-secret-change-in-prod"

# ─── WHATSAPP ───────────────────────────────────────────────────
# Include country code, no spaces or dashes
NEXT_PUBLIC_WHATSAPP_NUMBER="+919876543210"

# ─── EMAIL NOTIFICATIONS (Optional) ─────────────────────────────
# For sending order/inquiry email alerts
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
ADMIN_EMAIL="admin@craftura.com"

# ─── APP ────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NODE_ENV="development"
